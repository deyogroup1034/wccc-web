# Copy to .env.local and fill in real values.

# Supabase (project: wccc-dev) — Project URL + anon key from the dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — API key; verify the sending domain before going live.
# RESEND_FROM_EMAIL: leave blank to use the testable onboarding domain.
# CONTACT_TO_EMAIL: where the contact form sends. While testing with the
# onboarding domain, this must be the Resend account owner's email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=
